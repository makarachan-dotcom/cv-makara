generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [pgcrypto]
}

model User {
  id                BigInt   @id @default(autoincrement())
  telegramId        BigInt   @unique @map("telegram_id")
  username          String?  @db.VarChar(64)
  firstName         String?  @map("first_name") @db.VarChar(128)
  lastName          String?  @map("last_name") @db.VarChar(128)
  photoUrl          String?  @map("photo_url") @db.VarChar(512)
  // Authorization role. ADMIN is granted automatically during the Telegram
  // login handshake when the verified Telegram ID is in ADMIN_TELEGRAM_IDS.
  role              String   @default("USER") @db.VarChar(16)
  authDate          DateTime @map("auth_date") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt       DateTime @default(now()) @map("last_login_at") @db.Timestamptz(6)

  cvs               CV[]
  generations       Generation[]
  streak            Streak?
  checkIns          CheckIn[]
  templateUnlocks   TemplateUnlock[]
  sessions          Session[]
  cvDrafts          CvDraft[]
  cvHistory         CVHistory[]
  certificates      Certificate[]

  @@index([username])
  @@map("users")
}

model Session {
  id          String   @id @db.Uuid
  userId      BigInt   @map("user_id")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  ipAddress   String?  @map("ip_address") @db.Inet

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model CV {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  templateId  String   @map("template_id") @db.VarChar(64)
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation  Generation?

  @@index([userId, createdAt])
  @@map("cvs")
}

model Generation {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  cvId        BigInt?  @unique @map("cv_id")
  draftId     BigInt?  @map("draft_id")
  templateId  String   @map("template_id") @db.VarChar(64)
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv          CV?      @relation(fields: [cvId], references: [id], onDelete: SetNull)
  draft       CvDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([userId, generatedAt])
  @@index([draftId])
  @@map("generations")
}

// =============================================================================
// CvDraft
// The Khmer-first content draft produced by the AI Khmer Interviewer. At most
// ONE row per user may be in the ACTIVE state (enforced by a partial unique
// index in the raw migration); saving a new draft archives the previous active
// one inside a single transaction so the interview -> saved-draft transition is
// atomic. `data` holds the validated MakaraCvDraft; `answers` keeps the raw
// Khmer interview answers for re-editing / audit.
// =============================================================================
model CvDraft {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  industry    String   @db.VarChar(32)
  status      String   @default("ACTIVE") @db.VarChar(16)
  data        Json
  answers     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([userId, status, updatedAt])
  @@map("cv_drafts")
}

// =============================================================================
// CVHistory
// -----------------------------------------------------------------------------
// Persistent, versioned record of every CV a user has built. This is the
// lifecycle ledger powering the "CV History Dashboard": each row snapshots the
// full processed MakaraCvDraft JSON payload, the chosen template/styling, and
// the raw Khmer interview answers so the user can "Rewrite" (re-hydrate the
// interviewer + editor) and re-export to PDF / PNG / ATS without starting over.
// =============================================================================
model CVHistory {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  cvId        BigInt?  @map("cv_id")
  title       String   @db.VarChar(200)
  industry    String   @db.VarChar(32)
  templateId  String   @map("template_id") @db.VarChar(64)
  // Full processed CV payload (MakaraCvDraft) + the styling snapshot.
  payload     Json
  // Raw Khmer interview answers, enabling lossless re-hydration on Rewrite.
  answers     Json     @default("{}")
  // Live styling chosen at save time (font key / line spacing / accent hex).
  styling     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("cv_history")
}

// =============================================================================
// Certificate
// -----------------------------------------------------------------------------
// Server-side vault for uploaded official credentials (e.g. the BacII diploma).
// The raw document NEVER appears on the public CV — only an opaque
// `verifyToken` is embedded in a "Scan to Verify" QR. Scanning resolves to the
// internal DRM viewer (/verify/cv/[token]/certificate) which renders the
// document behind the anti-screenshot shield.
//
// RLS is intentionally DISABLED (mirroring login_tokens): the verification page
// is reached WITHOUT a session, keyed only by the unguessable token. Owner-side
// reads/writes always filter by userId at the application layer.
// =============================================================================
model Certificate {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  verifyToken  String   @unique @map("verify_token") @db.VarChar(64)
  kind         String   @default("certificate") @db.VarChar(24)
  label        String   @db.VarChar(160)
  issuer       String   @default("ក្រសួងអប់រំ យុវជន និងកីឡា") @db.VarChar(200)
  mimeType     String   @map("mime_type") @db.VarChar(80)
  // Base64 data URL of the uploaded document (image/PDF). For very large
  // deployments swap this for an object-storage key; the schema is unchanged.
  fileData     String   @map("file_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("certificates")
}

model Streak {
  userId           BigInt   @id @map("user_id")
  currentCount     Int      @default(0) @map("current_count")
  lastCheckInDate  DateTime? @map("last_check_in_date") @db.Date
  longestCount     Int      @default(0) @map("longest_count")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model CheckIn {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  checkInDate  DateTime @map("check_in_date") @db.Date
  countAfter   Int      @map("count_after")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkInDate])
  @@index([userId, checkInDate])
  @@map("check_ins")
}

model TemplateUnlock {
  userId       BigInt   @map("user_id")
  templateId   String   @map("template_id") @db.VarChar(64)
  unlockedAt   DateTime @default(now()) @map("unlocked_at") @db.Timestamptz(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, templateId])
  @@map("template_unlocks")
}

// Pending login tokens for the bot deep-link auth flow.
// Lifecycle: PENDING -> AUTHENTICATED (by webhook) -> CONSUMED (by /api/auth/poll).
// Rows expire after LOGIN_TOKEN_TTL_MS and are GC'd opportunistically.
model LoginToken {
  token        String   @id @db.VarChar(64)
  status       String   @default("PENDING") @db.VarChar(16)
  telegramId   BigInt?  @map("telegram_id")
  username     String?  @db.VarChar(64)
  firstName    String?  @map("first_name") @db.VarChar(128)
  lastName     String?  @map("last_name") @db.VarChar(128)
  photoUrl     String?  @map("photo_url") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  authedAt     DateTime? @map("authed_at") @db.Timestamptz(6)
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@index([status, telegramId])
  @@map("login_tokens")
}
