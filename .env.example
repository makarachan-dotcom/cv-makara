# PostgreSQL / Supabase
DATABASE_URL="postgresql://user:password@host:5432/chrono_cv?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/chrono_cv?schema=public"

# Telegram bot used for the bot deep-link login flow (and the legacy Login
# Widget HMAC verification, still supported on /api/auth/telegram).
# Create via @BotFather. The token MUST be kept server-side only.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# Random secret that Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token
# header on every webhook POST. Generate with: openssl rand -hex 32
# Pass this together with TELEGRAM_BOT_TOKEN to scripts/setup-telegram-webhook.ts
# to register the webhook with Telegram.
TELEGRAM_WEBHOOK_SECRET=""

# Session cookie signing key. Generate with: openssl rand -hex 32
SESSION_SECRET=""

# AES-256-GCM key (32 bytes hex) used to encrypt the Telegram admin handle at rest.
# Generate with: openssl rand -hex 32
ADMIN_HANDLE_ENCRYPTION_KEY=""

# Pre-encrypted ciphertext of the admin Telegram handle (format: ivHex:tagHex:ctHex).
# Produce with scripts/encrypt-admin-handle.ts (see README).
ADMIN_HANDLE_CIPHERTEXT=""

# ---------------------------------------------------------------------------
# Automated ADMIN clearance allowlist. Comma-separated list of master admin
# Telegram USER IDs (the numeric id, NOT the @username). During the Telegram
# login handshake, any verified id in this list is instantly flagged role=ADMIN
# and bypasses ALL platform gates: the 7-day check-in streak, the rolling
# 2-generations-per-week cooldown, the 18 locked premium templates, and it
# unlocks the system administration analytics views.
#   e.g. ADMIN_TELEGRAM_IDS="123456789,987654321"
ADMIN_TELEGRAM_IDS=""

# Optional Redis URL for distributed atomic locking on the generation endpoint.
# When unset, Postgres row-level locking (SELECT FOR UPDATE) is used as the fallback.
REDIS_URL=""

# ---------------------------------------------------------------------------
# AI Khmer Interviewer — OPTIONAL LLM enrichment.
# When unset, the interviewer runs fully on the deterministic rule-based engine
# (no external call). When set, the synthesized Khmer summary is polished by an
# OpenAI-compatible chat endpoint (OpenAI / NVIDIA NIM / Together / etc.).
# ---------------------------------------------------------------------------
INTERVIEW_LLM_API_KEY=""
INTERVIEW_LLM_BASE_URL="https://api.openai.com/v1"
INTERVIEW_LLM_MODEL="gpt-4o-mini"

# Public origin (used to build absolute redirect URLs).
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

# ---------------------------------------------------------------------------
# Server-side PDF (headless Chromium). OPTIONAL.
# On serverless (Vercel / Lambda) leave this unset — the bundled
# @sparticuz/chromium binary is used automatically. For local dev or a custom
# host, point this at an installed Chrome/Chromium executable.
#   e.g. /usr/bin/google-chrome  |  /opt/chromium/chrome
# ---------------------------------------------------------------------------
PUPPETEER_EXECUTABLE_PATH=""
